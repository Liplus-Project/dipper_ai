# dipper_ai user.conf
# Copy this file to user.conf and fill in your credentials.
# Place at /etc/dipper_ai/user.conf (or set DIPPER_AI_CONFIG env var).
#
# Format rules:
#   KEY=value          plain assignment
#   KEY=on / off       boolean (also accepts: 1/0, true/false)
#   # comment          whole-line comment
#   VALUE # comment    inline comment (value must not contain " #")
#   "value"            surrounding quotes are stripped automatically

# ---------------------------------------------------------------------------
# State directory  (cache files, lock files, timestamps)
# ---------------------------------------------------------------------------
STATE_DIR=/etc/dipper_ai/state

# ---------------------------------------------------------------------------
# IP address families
# ---------------------------------------------------------------------------
IPV4=on                 # Fetch and track IPv4 (default: on)
IPV6=off                # Fetch and track IPv6 (default: off)
IPV4_DDNS=on            # Update DDNS with IPv4 / A record (default: on)
IPV6_DDNS=on            # Update DDNS with IPv6 / AAAA record (default: on)

# ---------------------------------------------------------------------------
# Time gates  (minutes)
#   UPDATE_TIME   min 3    — how often the periodic update runs
#   DDNS_TIME     min 1    — how often DDNS is updated when IP changes
#   IP_CACHE_TIME 0=off    — how long the IP cache is valid (min 15 when on)
#   ERR_CHK_TIME  0=off    — how often err_mail mode runs  (min  1 when on)
# ---------------------------------------------------------------------------
UPDATE_TIME=1440        # 1 day
DDNS_TIME=1             # 1 minute
IP_CACHE_TIME=0         # disabled
ERR_CHK_TIME=0          # disabled

# ---------------------------------------------------------------------------
# MyDNS  (https://www.mydns.jp)
# Add more entries as MYDNS_1_*, MYDNS_2_*, etc.
# ---------------------------------------------------------------------------
#MYDNS_0_ID=mydnsXXXXXX
#MYDNS_0_PASS=yourpassword
#MYDNS_0_DOMAIN=home.example.com
#MYDNS_0_IPV4=on
#MYDNS_0_IPV6=off

# Optional: override default login endpoints
#MYDNS_IPV4_URL=https://ipv4.mydns.jp/login.html
#MYDNS_IPV6_URL=https://ipv6.mydns.jp/login.html

# ---------------------------------------------------------------------------
# Cloudflare  (one block per DNS record; add CF_1_*, CF_2_*, etc. for more)
# CF_0_ZONE  : zone name, e.g. "example.com"  (zone ID is resolved automatically)
# CF_0_DOMAIN: FQDN of the record, e.g. "home.example.com"
# ---------------------------------------------------------------------------
#CF_0_ENABLED=off
#CF_0_API=your_cloudflare_api_token
#CF_0_ZONE=example.com
#CF_0_DOMAIN=home.example.com
#CF_0_IPV4=on
#CF_0_IPV6=off

#CF_1_ENABLED=off
#CF_1_API=your_cloudflare_api_token
#CF_1_ZONE=example.com
#CF_1_DOMAIN=other.example.com
#CF_1_IPV4=on
#CF_1_IPV6=off

# Optional: override Cloudflare API base URL
#CLOUDFLARE_URL=https://api.cloudflare.com/client/v4/zones

# ---------------------------------------------------------------------------
# Email notification  (via sendmail)
#   EMAIL_CHK_DDNS  notify when IP address changes
#   EMAIL_UP_DDNS   notify on every periodic update
# ---------------------------------------------------------------------------
#EMAIL_CHK_DDNS=off
#EMAIL_UP_DDNS=off
#EMAIL_ADR=you@example.com
